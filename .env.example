# MCP Server Configuration
# Copy this file to .env and configure for your environment

# Hub Server URL (where the hub server is running)
HUB_URL=http://localhost:3000

# Agent Configuration
# Unique identifier for this agent instance
AGENT_ID=claude-main

# Display name for this agent
AGENT_NAME=Claude

# Character sprite to use (Adam, cat, etc.)
AGENT_SPRITE=Adam

# Owner/User Configuration
# Unique identifier for the person running this agent
OWNER_ID=default-owner

# Display name for the owner
OWNER_NAME=Owner

# Authentication: API Key
# Must match the API_KEY set on the hub server
# Leave unset if the hub has no API_KEY configured
# API_KEY=your-secret-key-here

# Production Settings (uncomment for production)
# HUB_URL=https://your-hub-domain.com
# AGENT_ID=production-agent-1
# API_KEY=your-secret-key-here
